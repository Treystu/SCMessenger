{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "FreeTierEc2InstanceLifecycle",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances",
        "ec2:StartInstances",
        "ec2:StopInstances",
        "ec2:TerminateInstances",
        "ec2:RebootInstances"
      ],
      "Resource": "arn:aws:ec2:*:*:instance/*",
      "Condition": {
        "StringEquals": {
          "ec2:InstanceType": ["t2.micro", "t3.micro", "m7i-flex.large"]
        }
      }
    },
    {
      "Sid": "Ec2LaunchSupportResources",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances"
      ],
      "Resource": [
        "arn:aws:ec2:*:*:volume/*",
        "arn:aws:ec2:*:*:network-interface/*",
        "arn:aws:ec2:*:*:subnet/*",
        "arn:aws:ec2:*:*:security-group/*",
        "arn:aws:ec2:*:*:key-pair/*",
        "arn:aws:ec2:*::image/*"
      ]
    },
    {
      "Sid": "FreeTierEbsVolumeCap",
      "Effect": "Allow",
      "Action": "ec2:RunInstances",
      "Resource": "arn:aws:ec2:*:*:volume/*",
      "Condition": {
        "NumericLessThanEquals": {
          "ec2:VolumeSize": "30"
        },
        "StringEquals": {
          "ec2:VolumeType": ["gp2", "gp3"]
        }
      }
    },
    {
      "Sid": "NetworkingReadAndSecurityGroups",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateSecurityGroup",
        "ec2:DeleteSecurityGroup",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:AuthorizeSecurityGroupEgress",
        "ec2:RevokeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupEgress",
        "ec2:CreateTags",
        "ec2:DeleteTags",
        "ec2:CreateKeyPair",
        "ec2:DeleteKeyPair",
        "ec2:ImportKeyPair"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": ["us-east-1"]
        }
      }
    },
    {
      "Sid": "ReadOnlyDescribe",
      "Effect": "Allow",
      "Action": [
        "ec2:Describe*",
        "ec2:GetConsoleOutput"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyEverythingOutsideFreeTierRegion",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateSecurityGroup",
        "ec2:CreateKeyPair"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": ["us-east-1"]
        }
      }
    },
    {
      "Sid": "DenyElasticIpAllocationBeyondFreeAllowance",
      "Effect": "Deny",
      "Action": [
        "ec2:AllocateAddress"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyExpensiveOrDangerousActions",
      "Effect": "Deny",
      "Action": [
        "ec2:PurchaseReservedInstancesOffering",
        "ec2:ModifyReservedInstances",
        "ec2:PurchaseHostReservation",
        "ec2:ModifyInstanceAttribute",
        "ec2:CreateFleet",
        "ec2:RequestSpotFleet",
        "ec2:RequestSpotInstances",
        "iam:*",
        "organizations:*",
        "account:*",
        "s3:*",
        "rds:*",
        "eks:*",
        "ecs:*",
        "lambda:*",
        "sagemaker:*",
        "elasticmapreduce:*",
        "redshift:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "BudgetsReadAndAlarmSetup",
      "Effect": "Allow",
      "Action": [
        "budgets:ViewBudget",
        "budgets:CreateBudget",
        "budgets:ModifyBudget",
        "ce:GetCostAndUsage",
        "ce:GetCostForecast",
        "cloudwatch:PutMetricAlarm",
        "cloudwatch:DescribeAlarms",
        "sns:CreateTopic",
        "sns:Subscribe"
      ],
      "Resource": "*"
    }
  ]
}
