{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AttachDetachQuarantinePolicyOnRelayUser",
      "Effect": "Allow",
      "Action": [
        "iam:AttachUserPolicy",
        "iam:DetachUserPolicy",
        "iam:ListAttachedUserPolicies"
      ],
      "Resource": "arn:aws:iam::*:user/scmessenger-relay-orchestrator"
    },
    {
      "Sid": "StopTaggedRelayInstances",
      "Effect": "Allow",
      "Action": "ec2:StopInstances",
      "Resource": "arn:aws:ec2:*:*:instance/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/Name": "scmessenger-farm-relay"
        }
      }
    },
    {
      "Sid": "DescribeInstancesReadOnly",
      "Effect": "Allow",
      "Action": "ec2:DescribeInstances",
      "Resource": "*"
    }
  ]
}
