+    #[test]
+    fn test_flush_peer_messages() {
+        let mut outbox = Outbox::new();
+        
+        // Set up a mock send callback
+        let sent_messages = Arc::new(std::sync::Mutex::new(Vec::new()));
+        let sent_clone = sent_messages.clone();
+        
+        outbox.set_send_callback(move |recipient: &str, data: Vec<u8>| {
+            let mut guard = sent_clone.lock().unwrap();
+            guard.push((recipient.to_string(), data));
+            Ok(())
+        });
+        
+        // Enqueue messages
+        outbox.enqueue(make_msg("msg1", "peer_a")).unwrap();
+        outbox.enqueue(make_msg("msg2", "peer_a")).unwrap();
+        outbox.enqueue(make_msg("msg3", "peer_b")).unwrap();
+        
+        // Mark peer_a as connected
+        outbox.peer_connected("peer_a");
+        
+        // Flush should send peer_a's messages
+        let sent = outbox.flush_peer_messages("peer_a").unwrap();
+        assert_eq!(sent, 2);
+        assert_eq!(outbox.total_count(), 1); // Only peer_b's message remains
+    }
+
+    #[test]
+    fn test_flush_with_retry_backoff() {
+        let mut outbox = Outbox::new();
+        let attempt_count = Arc::new(std::sync::atomic::AtomicU32::new(0));
+        let attempt_clone = attempt_count.clone();
+        
+        // Set up a failing send callback
+        outbox.set_send_callback(move |_recipient: &str, _data: Vec<u8>| {
+            attempt_clone.fetch_add(1, std::sync::atomic::Ordering::SeqCst);
+            Err("Simulated network failure".to_string())
+        });
+        
+        // Enqueue message
+        outbox.enqueue(make_msg("msg1", "peer_a")).unwrap();
+        
+        // Mark peer as connected and flush
+        outbox.peer_connected("peer_a");
+        let _ = outbox.flush_peer_messages("peer_a");
+        
+        // Message should remain with incremented attempt count
+        let msgs = outbox.peek_for_peer("peer_a");
+        assert_eq!(msgs.len(), 1);
+        assert_eq!(msgs[0].attempts, 1);
+        assert!(msgs[0].next_retry_at.is_some());
+        assert_eq!(attempt_count.load(std::sync::atomic::Ordering::SeqCst), 1);
+    }
