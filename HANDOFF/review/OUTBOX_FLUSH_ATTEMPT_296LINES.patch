+    /// Set the callback for sending messages to peers
+    pub fn set_send_callback<F>(&mut self, callback: F)
+    where
+        F: Fn(&str, Vec<u8>) -> Result<(), String> + Send + Sync + 'static,
+    {
+        self.send_callback = Some(Arc::new(callback));
+    }
+
+    /// Notify outbox that a peer has connected
+    pub fn peer_connected(&mut self, peer_id: &str) {
+        self.peer_connections.insert(peer_id.to_string(), true);
+        // Attempt to flush queued messages for this peer
+        let _ = self.flush_peer_messages(peer_id);
+    }
+
+    /// Notify outbox that a peer has disconnected
+    pub fn peer_disconnected(&mut self, peer_id: &str) {
+        self.peer_connections.insert(peer_id.to_string(), false);
+    }
+
+    /// Check if a peer is connected
+    pub fn is_peer_connected(&self, peer_id: &str) -> bool {
+        self.peer_connections.get(peer_id).copied().unwrap_or(false)
+    }
+
+    /// Flush all queued messages for a specific peer
+    /// Returns number of successfully sent messages
+    pub fn flush_peer_messages(&mut self, peer_id: &str) -> Result<usize, String> {
+        let mut sent_count = 0;
+        let now = web_time::SystemTime::now()
+            .duration_since(web_time::UNIX_EPOCH)
+            .unwrap_or_default()
+            .as_millis() as u64;
+
+        // Get messages that are ready for retry (next_retry_at <= now or never set)
+        let pending_msgs = match &self.backend {
+            OutboxBackend::Memory { queues, .. } => {
+                if let Some(queue) = queues.get(peer_id) {
+                    queue
+                        .iter()
+                        .filter(|m| {
+                            m.next_retry_at.is_none() || m.next_retry_at.unwrap() <= now
+                        })
+                        .cloned()
+                        .collect()
+                } else {
+                    Vec::new()
+                }
+            }
+            OutboxBackend::Persistent(db) => {
+                let prefix_str = format!(
+                    "{}{}_",
+                    String::from_utf8_lossy(QUEUE_PREFIX),
+                    peer_id
+                );
+                if let Ok(results) = db.scan_prefix(prefix_str.as_bytes()) {
+                    results
+                        .into_iter()
+                        .filter_map(|(_, value)| bincode::deserialize::<QueuedMessage>(&value).ok())
+                        .filter(|m| {
+                            m.next_retry_at.is_none() || m.next_retry_at.unwrap() <= now
+                        })
+                        .collect()
+                } else {
+                    Vec::new()
+                }
+            }
+        };
+
+        if pending_msgs.is_empty() {
+            return Ok(0);
+        }
+
+        let send_fn = self.send_callback.clone().ok_or("No send callback configured")?;
+
+        for msg in pending_msgs {
+            // Check max attempts
+            if msg.attempts >= MAX_DELIVERY_ATTEMPTS {
+                tracing::warn!(
+                    event = "outbox_max_attempts",
+                    message_id = %msg.message_id,
+                    recipient_id = %msg.recipient_id,
+                    attempts = msg.attempts,
+                    action = "removing_from_queue"
+                );
+                let _ = self.remove(&msg.message_id);
+                continue;
+            }
+
+            // Attempt to send
+            match send_fn(&msg.recipient_id, msg.envelope_data.clone()) {
+                Ok(_) => {
+                    tracing::info!(
+                        event = "outbox_send_success",
+                        message_id = %msg.message_id,
+                        recipient_id = %msg.recipient_id,
+                        attempts = msg.attempts + 1
+                    );
+                    let _ = self.remove(&msg.message_id);
+                    sent_count += 1;
+                }
+                Err(e) => {
+                    tracing::warn!(
+                        event = "outbox_send_failure",
+                        message_id = %msg.message_id,
+                        recipient_id = %msg.recipient_id,
+                        error = %e,
+                        attempts = msg.attempts + 1
+                    );
+                    // Increment attempt and schedule retry with exponential backoff
+                    let backoff_ms = std::cmp::min(
+                        INITIAL_BACKOFF_MS * 2u64.pow(msg.attempts.min(10)),
+                        MAX_BACKOFF_MS,
+                    );
+                    let next_retry = now.saturating_add(backoff_ms);
+                    
+                    let mut updated_msg = msg.clone();
+                    updated_msg.attempts = updated_msg.attempts.saturating_add(1);
+                    updated_msg.last_attempt_at = Some(now);
+                    updated_msg.next_retry_at = Some(next_retry);
+                    
+                    // Update message in outbox
+                    self.update_message(updated_msg)?;
+                }
+            }
+        }
+
+        Ok(sent_count)
+    }
+
+    /// Update a message in the outbox (used for retry scheduling)
+    fn update_message(&mut self, msg: QueuedMessage) -> Result<(), String> {
+        // Remove old entry first
+        let _ = self.remove(&msg.message_id);
+        // Re-enqueue with updated fields
+        self.enqueue(msg)
+    }
+
+    /// Flush all pending messages for all connected peers
+    pub fn flush_all_pending(&mut self) -> Result<usize, String> {
+        let mut total_sent = 0;
+        
+        // Get list of connected peers
+        let connected_peers: Vec<String> = self.peer_connections
+            .iter()
+            .filter(|(_, &connected)| connected)
+            .map(|(peer_id, _)| peer_id.clone())
+            .collect();
+        
+        for peer_id in connected_peers {
+            match self.flush_peer_messages(&peer_id) {
+                Ok(count) => total_sent += count,
+                Err(e) => {
+                    tracing::error!(
+                        event = "outbox_flush_error",
+                        peer_id = %peer_id,
+                        error = %e
+                    );
+                }
+            }
+        }
+        
+        Ok(total_sent)
+    }
