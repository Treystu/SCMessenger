{
  "version": "2.2",
  "max_concurrent": 2,
  "default_agent": "orchestrator",
  "launch_mode": "cli_only",
  "agents": [
    {
      "name": "orchestrator",
      "launch_type": "cli",
      "model": "kimi-k2.6:cloud",
      "fallback_model": "qwen3-coder:480b:cloud",
      "purpose": "Lead coordinator: tracks progress across all phases, delegates tasks, verifies completion, manages HANDOFF state, ensures the swarm stays on track",
      "task_patterns": [
        "ORCHESTRATE",
        "COORDINATE",
        "DELEGATE",
        "VERIFY",
        "TRACK"
      ],
      "file_domains": [
        "HANDOFF/",
        ".claude/",
        "scripts/",
        "docs/"
      ],
      "max_per_type": 1
    },
    {
      "name": "architect-planner",
      "launch_type": "cli",
      "model": "deepseek-v4-pro:cloud",
      "fallback_model": "deepseek-v3.2:cloud",
      "purpose": "High-level architecture planning AND precision validation: designs system architecture, plans implementation order, validates correctness of crypto/protocol/security code, performs adversarial review",
      "task_patterns": [
        "ARCHITECTURE",
        "PLAN",
        "DESIGN",
        "VALIDATE",
        "SECURITY",
        "CRYPTO",
        "AUDIT",
        "REVIEW"
      ],
      "file_domains": [
        "docs/",
        "REMAINING_WORK_TRACKING.md",
        "core/src/crypto/",
        "core/src/privacy/"
      ],
      "max_per_type": 1
    },
    {
      "name": "rust-coder",
      "launch_type": "cli",
      "model": "glm-5.1:cloud",
      "fallback_model": "qwen3-coder-next:cloud",
      "purpose": "Rust core implementation: identity, crypto, transport, store, relay modules. glm-5.1 has proven Rust output quality",
      "task_patterns": [
        "RUST",
        "CORE",
        "PROTOCOL",
        "CRYPTO_IMPL",
        "WASM",
        "MOBILE_BRIDGE"
      ],
      "file_domains": [
        "core/",
        "wasm/"
      ],
      "max_per_type": 1
    },
    {
      "name": "implementer",
      "launch_type": "cli",
      "model": "qwen3-coder-next:cloud",
      "fallback_model": "glm-5.1:cloud",
      "purpose": "Rapid feature landing: general coding, bug fixes, platform client implementation",
      "task_patterns": [
        "IMPLEMENTATION",
        "BUG",
        "FIX",
        "FEATURE",
        "CLI",
        "PLATFORM"
      ],
      "file_domains": [
        "android/",
        "cli/src/",
        "mobile/src/",
        "iOS/"
      ],
      "max_per_type": 2
    },
    {
      "name": "gatekeeper-reviewer",
      "launch_type": "cli",
      "model": "kimi-k2-thinking:cloud",
      "fallback_model": "kimi-k2.6:cloud",
      "purpose": "Pre-merge verification: final code review gate, ensures build passes, tests pass, docs synced",
      "task_patterns": [
        "MERGE",
        "RELEASE",
        "FINAL_REVIEW",
        "GATE"
      ],
      "file_domains": [],
      "max_per_type": 1
    },
    {
      "name": "worker",
      "launch_type": "cli",
      "model": "gemma4:31b:cloud",
      "fallback_model": "devstral-2:123b:cloud",
      "purpose": "Unit tests, UniFFI bindings, documentation, platform engineering, small changes under 200 LOC",
      "task_patterns": [
        "PLATFORM",
        "BINDINGS",
        "TEST",
        "DOCS",
        "GRADLE"
      ],
      "file_domains": [
        "core/tests/",
        "android/app/src/",
        "android/app/build.gradle",
        "android/app/build.gradle.kts",
        "android/app/src/main/java/",
        "android/app/src/test/",
        "android/app/src/androidTest/"
      ],
      "max_per_type": 1
    },
    {
      "name": "triage-router",
      "launch_type": "cli",
      "model": "gemini-3-flash-preview:cloud",
      "fallback_model": "deepseek-v4-flash:cloud",
      "purpose": "Quick triage, lint fixes, minor edits under 50 LOC, CI gatekeeping, parsing",
      "task_patterns": [
        "LINT",
        "TRIAGE",
        "QUICK",
        "CI",
        "FMT"
      ],
      "file_domains": [],
      "max_per_type": 1
    },
    {
      "name": "micro-batch-processor",
      "launch_type": "cli",
      "model": "gemini-3-flash-preview:cloud",
      "fallback_model": "deepseek-v4-flash:cloud",
      "purpose": "Process batches of micro-tasks (lint, quick fixes, formatting) to reduce API overhead",
      "task_patterns": [
        "BATCH",
        "MICRO_BATCH"
      ],
      "file_domains": [
        "HANDOFF/batches/"
      ],
      "max_per_type": 1
    },
    {
      "name": "wiring-verifier",
      "launch_type": "cli",
      "model": "deepseek-v4-pro:cloud",
      "fallback_model": "deepseek-v3.2:cloud",
      "purpose": "Full repo-wide wiring verification: checks all module connections, IronCore entry points, cross-module dependencies, API surface completeness",
      "task_patterns": [
        "WIRING",
        "VERIFY",
        "INTEGRATION",
        "CONNECTIVITY"
      ],
      "file_domains": [],
      "max_per_type": 1
    },
    {
      "name": "CLIBetaTester",
      "launch_type": "cli",
      "model": "qwen3-coder:480b:cloud",
      "fallback_model": "glm-5.1:cloud",
      "purpose": "Acts as an aggressive Beta User against the Rust Core daemon. Tests the JSON-RPC bridge and libp2p mesh.",
      "task_patterns": [
        "BETA",
        "CLI",
        "CORE_TEST",
        "CRASH",
        "STRESS"
      ],
      "file_domains": [],
      "max_per_type": 1
    },
    {
      "name": "vision-analyst",
      "launch_type": "cli",
      "model": "qwen3-vl:235b:cloud",
      "fallback_model": "nemotron-3-super:cloud",
      "purpose": "Visual analysis of screenshots, diagrams, UI mockups, log visualizations",
      "task_patterns": [
        "VISION",
        "SCREENSHOT",
        "UI_REVIEW",
        "DIAGRAM"
      ],
      "file_domains": [],
      "max_per_type": 1
    }
  ],
