{
  "version": "2.2",
  "max_concurrent": 2,
  "default_agent": "architect",
  "launch_mode": "cli_only",
  "agents": [
    {
      "name": "architect",
      "launch_type": "cli",
      "model": "qwen3-coder:480b:cloud",
      "fallback_model": "qwen3.5:397b:cloud",
      "purpose": "System design, planning, architecture decisions, multi-file reasoning",
      "task_patterns": ["ARCHITECTURE", "PLAN", "DESIGN", "REFACTOR"],
      "max_per_type": 1
    },
    {
      "name": "implementer",
      "launch_type": "cli",
      "model": "qwen3-coder-next:cloud",
      "fallback_model": "glm-5.1:cloud",
      "purpose": "Rapid feature landing, general coding, bug fixes, feature implementation",
      "task_patterns": ["IMPLEMENTATION", "BUG", "FIX", "FEATURE", "WASM", "IOS", "ANDROID"],
      "max_per_type": 2
    },
    {
      "name": "precision-validator",
      "launch_type": "cli",
      "model": "deepseek-v3.2:cloud",
      "fallback_model": "deepseek-v4-pro:cloud",
      "purpose": "Cryptography, math, protocol validation, security audit, unsafe block verification",
      "task_patterns": ["SECURITY", "CRYPTO", "AUDIT", "VERIFY", "REVIEW", "GATE"],
      "max_per_type": 1
    },
    {
      "name": "worker",
      "launch_type": "cli",
      "model": "devstral-2:123b:cloud",
      "fallback_model": "gemma4:31b:cloud",
      "purpose": "Unit tests, UniFFI bindings, documentation, platform engineering",
      "task_patterns": ["PLATFORM", "BINDINGS", "TEST", "DOCS"],
      "max_per_type": 1
    },
    {
      "name": "triage-router",
      "launch_type": "cli",
      "model": "gemini-3-flash-preview:cloud",
      "fallback_model": "deepseek-v4-flash:cloud",
      "purpose": "Quick triage, lint fixes, minor edits under 50 LOC, CI gatekeeping, parsing",
      "task_patterns": ["LINT", "TRIAGE", "QUICK", "CI"],
      "max_per_type": 1
    },
    {
      "name": "gatekeeper-reviewer",
      "launch_type": "cli",
      "model": "kimi-k2-thinking:cloud",
      "fallback_model": "kimi-k2.6:cloud",
      "purpose": "Pre-merge verification, final code review gate",
      "task_patterns": ["MERGE", "RELEASE", "FINAL_REVIEW"],
      "max_per_type": 1
    },
    {
      "name": "swarm-orchestrator",
      "launch_type": "cli",
      "model": "mistral-large-3:675b:cloud",
      "fallback_model": "cogito-2.1:671b:cloud",
      "purpose": "Pipeline management, multi-agent coordination",
      "task_patterns": ["ORCHESTRATE", "PIPELINE", "SWARM"],
      "max_per_type": 1
    },
    {
      "name": "rust-coder",
      "launch_type": "cli",
      "model": "glm-5.1:cloud",
      "fallback_model": "qwen3-coder-next:cloud",
      "purpose": "Rust core, protocol implementation, WASM — glm-5.1 has proven Rust output",
      "task_patterns": ["RUST", "CORE", "PROTOCOL", "CRYPTO_IMPL", "WASM"],
      "max_per_type": 1
    },
    {
      "name": "CLIBetaTester",
      "launch_type": "cli",
      "model": "qwen3-coder:480b:cloud",
      "fallback_model": "glm-5.1:cloud",
      "purpose": "Acts as an aggressive Beta User against the Rust Core daemon. Tests the JSON-RPC bridge and libp2p mesh.",
      "system_prompt_additions": "You are the CLIBetaTester. Your job is to interact with the SCMessenger Core daemon using the core_cli_driver skill. Start the node, inject unexpected JSON-RPC payloads, simulate offline/online network states, and attempt to send messages. If the daemon crashes or hangs, use the dump_logs command, save the stack trace to HANDOFF/IN_PROGRESS/CORE_CRASH_REPORT_<timestamp>.md, and request RCA.",
      "task_patterns": ["BETA", "CLI", "CORE_TEST", "CRASH", "STRESS"],
      "max_per_type": 1
    },
    {
      "name": "deep-analyst",
      "launch_type": "cli",
      "model": "deepseek-v4-pro:cloud",
      "fallback_model": "deepseek-v3.2:cloud",
      "purpose": "Deep analysis, complex bug RCA, protocol correctness proofs, multi-step reasoning",
      "task_patterns": ["RCA", "ANALYSIS", "PROOF", "CORRECTNESS", "DEEP_DIVE"],
      "max_per_type": 1
    },
    {
      "name": "vision-analyst",
      "launch_type": "cli",
      "model": "qwen3-vl:235b:cloud",
      "fallback_model": "nematron-3-super:cloud",
      "purpose": "Visual analysis of screenshots, diagrams, UI mockups, log visualizations",
      "task_patterns": ["VISION", "SCREENSHOT", "UI_REVIEW", "DIAGRAM"],
      "max_per_type": 1
    }
  ],
  "available_models": [
