{
  "version": "2.3",
  "policy": "local_only",
  "policy_note": "Per Lucas directive 2026-06-06: NO cloud models, NO :cloud suffix, all models must be local Ollama-resident at 127.0.0.1:11434",
  "max_concurrent": 1,
  "default_agent": "orchestrator",
  "launch_mode": "cli_only",
  "ollama_base_url": "http://127.0.0.1:11434/v1",
  "available_local_models": [
    {"name": "scm-thinker:14b", "size_gb": 4.7, "best_for": "orchestration, deep reasoning"},
    {"name": "scm-coder:7b", "size_gb": 4.7, "best_for": "rust, general coding"},
    {"name": "qwen2.5-coder:7b", "size_gb": 4.7, "best_for": "coding worker"},
    {"name": "deepseek-r1-distill-14b-iq2xs", "size_gb": 4.7, "best_for": "deep analysis, low-RAM"},
    {"name": "qwen2.5-coder:1.5b", "size_gb": 1.0, "best_for": "micro/batch tasks"},
    {"name": "llama3.2:3b", "size_gb": 2.0, "best_for": "trivial fallback"}
  ],
  "agents": [
    {
      "name": "orchestrator",
      "launch_type": "cli",
      "model": "scm-thinker:14b",
      "fallback_model": "scm-coder:7b",
      "purpose": "Lead coordinator: tracks progress across all phases, delegates tasks, verifies completion, manages HANDOFF state. LOCAL ONLY.",
      "task_patterns": ["ORCHESTRATE", "COORDINATE", "DELEGATE", "VERIFY", "TRACK"],
      "file_domains": ["HANDOFF/", ".claude/", "scripts/", "docs/"],
      "max_per_type": 1,
      "cloud_allowed": false
    },
    {
      "name": "architect-planner",
      "launch_type": "cli",
      "model": "scm-thinker:14b",
      "fallback_model": "scm-coder:7b",
      "purpose": "High-level architecture planning AND precision validation. LOCAL 14B replaces cloud 480B flagship.",
      "task_patterns": ["ARCHITECTURE", "PLAN", "DESIGN", "VALIDATE", "SECURITY", "CRYPTO", "AUDIT", "REVIEW"],
      "file_domains": ["docs/", "REMAINING_WORK_TRACKING.md", "core/src/crypto/", "core/src/privacy/"],
      "max_per_type": 1,
      "cloud_allowed": false
    },
    {
      "name": "rust-coder",
      "launch_type": "cli",
      "model": "scm-coder:7b",
      "fallback_model": "qwen2.5-coder:7b",
      "purpose": "Rust core implementation: identity, crypto, transport, store, relay. Best local Rust per prior benchmark.",
      "task_patterns": ["RUST", "CORE", "PROTOCOL", "CRYPTO_IMPL", "WASM", "MOBILE_BRIDGE"],
      "file_domains": ["core/", "wasm/"],
      "max_per_type": 1,
      "cloud_allowed": false
    },
    {
      "name": "implementer",
      "launch_type": "cli",
      "model": "scm-coder:7b",
      "fallback_model": "qwen2.5-coder:7b",
      "purpose": "Rapid feature landing: general coding, bug fixes, platform client implementation.",
      "task_patterns": ["IMPLEMENTATION", "BUG", "FIX", "FEATURE", "CLI", "PLATFORM"],
      "file_domains": ["android/", "cli/src/", "mobile/src/", "iOS/"],
      "max_per_type": 2,
      "cloud_allowed": false
    },
    {
      "name": "gatekeeper-reviewer",
      "launch_type": "cli",
      "model": "scm-thinker:14b",
      "fallback_model": "scm-coder:7b",
      "purpose": "Pre-merge verification: final code review gate, ensures build passes, tests pass, docs synced. LOCAL REVIEW.",
      "task_patterns": ["MERGE", "RELEASE", "FINAL_REVIEW", "GATE"],
      "file_domains": [],
      "max_per_type": 1,
      "cloud_allowed": false
    },
    {
      "name": "worker",
      "launch_type": "cli",
      "model": "qwen2.5-coder:7b",
      "fallback_model": "llama3.2:3b",
      "purpose": "Unit tests, UniFFI bindings, documentation, platform engineering, small changes under 200 LOC.",
      "task_patterns": ["PLATFORM", "BINDINGS", "TEST", "DOCS", "GRADLE"],
      "file_domains": ["core/tests/", "android/app/src/", "android/app/build.gradle", "android/app/build.gradle.kts", "android/app/src/main/java/", "android/app/src/test/", "android/app/src/androidTest/"],
      "max_per_type": 1,
      "cloud_allowed": false
    },
    {
      "name": "triage-router",
      "launch_type": "cli",
      "model": "qwen2.5-coder:1.5b",
      "fallback_model": "llama3.2:3b",
      "purpose": "Quick triage, lint fixes, minor edits under 50 LOC, CI gatekeeping, parsing. 1.5B is plenty for triage.",
      "task_patterns": ["LINT", "TRIAGE", "QUICK", "CI", "FMT"],
      "file_domains": [],
      "max_per_type": 1,
      "cloud_allowed": false
    },
    {
      "name": "micro-batch-processor",
      "launch_type": "cli",
      "model": "qwen2.5-coder:1.5b",
      "fallback_model": "llama3.2:3b",
      "purpose": "Process batches of micro-tasks (lint, quick fixes, formatting) to reduce overhead.",
      "task_patterns": ["BATCH", "MICRO_BATCH"],
      "file_domains": ["HANDOFF/batches/"],
      "max_per_type": 1,
      "cloud_allowed": false
    },
    {
      "name": "wiring-verifier",
      "launch_type": "cli",
      "model": "deepseek-r1-distill-14b-iq2xs",
      "fallback_model": "scm-thinker:14b",
      "purpose": "Full repo-wide wiring verification: checks all module connections, IronCore entry points, cross-module dependencies. DeepSeek R1 distill for the deep traversal.",
      "task_patterns": ["WIRING", "VERIFY", "INTEGRATION", "CONNECTIVITY"],
      "file_domains": [],
      "max_per_type": 1,
      "cloud_allowed": false
    },
    {
      "name": "CLIBetaTester",
      "launch_type": "cli",
      "model": "scm-coder:7b",
      "fallback_model": "qwen2.5-coder:7b",
      "purpose": "Aggressive Beta User against the Rust Core daemon. JSON-RPC bridge, libp2p mesh stress.",
      "task_patterns": ["BETA", "CLI", "CORE_TEST", "CRASH", "STRESS"],
      "file_domains": [],
      "max_per_type": 1,
      "cloud_allowed": false
    },
    {
      "name": "vision-analyst",
      "launch_type": "cli",
      "model": null,
      "fallback_model": null,
      "purpose": "DISABLED — no local multimodal model is loaded. Screenshot/UI review tasks must be deferred to human or wait for local vision model to be added.",
      "task_patterns": ["VISION", "SCREENSHOT", "UI_REVIEW", "DIAGRAM"],
      "file_domains": [],
      "max_per_type": 0,
      "cloud_allowed": false,
      "status": "disabled_pending_local_vision"
    }
  ]
}
