# SCMessenger — enforce LF line endings on text files
# This prevents Windows checkouts from re-introducing CRLF, which breaks
# macOS bash shebangs and most cross-platform tooling.

# Default: LF for all text files
* text=auto eol=lf

# Shell scripts, gradle, python — must be LF
*.sh        text eol=lf
*.bash      text eol=lf
*.gradle    text eol=lf
*.gradle.kts text eol=lf
*.py        text eol=lf

# PowerShell — accept either (Windows native is CRLF, but LF works too)
*.ps1       text eol=crlf

# Rust source — LF
*.rs        text eol=lf

# Kotlin — LF
*.kt        text eol=lf
*.kts       text eol=lf

# Swift — LF
*.swift     text eol=lf

# Markdown — LF
*.md        text eol=lf

# YAML / JSON / TOML — LF
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf

# Properties — LF
*.properties text eol=lf

# Windows-specific files keep CRLF
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Binary files (no conversion)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.so        binary
*.dylib     binary
*.dll       binary
*.a         binary
*.apk       binary
*.aab       binary
*.keystore  binary

# GitHub lock files
.github/workflows/*.lock.yml linguist-generated=true merge=ours
