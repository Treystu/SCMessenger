#!/usr/bin/env bash
# SCMessenger Pre-Commit Hook
# Runs formatting, linting, and unit tests before allowing commit

set -e

echo "🔍 Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any checks fail
FAILED=0

# Function to print colored output
print_status() {
    if [ $1 -eq 0 ]; then
        echo -e "${GREEN}✓${NC} $2"
    else
        echo -e "${RED}✗${NC} $2"
        FAILED=1
    fi
}

# 1. Check Rust formatting
echo ""
echo "📝 Checking Rust formatting..."
if cargo fmt --all -- --check > /dev/null 2>&1; then
    print_status 0 "Rust formatting"
else
    print_status 1 "Rust formatting"
    echo -e "${YELLOW}Run 'cargo fmt --all' to fix formatting issues${NC}"
fi

# 2. Run Clippy
echo ""
echo "🔎 Running Clippy..."
if cargo clippy --workspace --all-targets -- -D warnings -A clippy::empty_line_after_doc_comments > /dev/null 2>&1; then
    print_status 0 "Clippy linting"
else
    print_status 1 "Clippy linting"
    echo -e "${YELLOW}Run 'cargo clippy --workspace --all-targets -- -D warnings' to see issues${NC}"
fi

# 3. Run unit tests (fast subset)
echo ""
echo "🧪 Running unit tests..."
if cargo test --workspace --lib --bins > /dev/null 2>&1; then
    print_status 0 "Unit tests"
else
    print_status 1 "Unit tests"
    echo -e "${YELLOW}Run 'cargo test --workspace --lib --bins' to see failures${NC}"
fi

# 4. Check for unwrap() in library code (excluding tests)
echo ""
echo "🚫 Checking for unwrap() in library code..."
UNWRAP_COUNT=$(rg -n '\.unwrap\(\)' core/src mobile/src --glob '!*test*' 2>/dev/null | wc -l || echo "0")
if [ "$UNWRAP_COUNT" -eq 0 ]; then
    print_status 0 "No unwrap() in library code"
else
    print_status 1 "Found $UNWRAP_COUNT unwrap() calls in library code"
    echo -e "${YELLOW}Use '?' or 'expect()' instead of 'unwrap()' in library code${NC}"
    rg -n '\.unwrap\(\)' core/src mobile/src --glob '!*test*' 2>/dev/null || true
fi

# 5. Check for println! in library code (excluding tests)
echo ""
echo "🚫 Checking for println! in library code..."
PRINTLN_COUNT=$(rg -n 'println!' core/src mobile/src --glob '!*test*' 2>/dev/null | wc -l || echo "0")
if [ "$PRINTLN_COUNT" -eq 0 ]; then
    print_status 0 "No println! in library code"
else
    print_status 1 "Found $PRINTLN_COUNT println! calls in library code"
    echo -e "${YELLOW}Use tracing macros instead of println! in library code${NC}"
    rg -n 'println!' core/src mobile/src --glob '!*test*' 2>/dev/null || true
fi

# Summary
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 0
else
    echo -e "${RED}✗ Some pre-commit checks failed${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "To skip these checks (not recommended), use: git commit --no-verify"
    exit 1
fi
