{
  "$schema": "https://opencode.ai/config.json",
  "command": {
    "orchestrate": {
      "template": "SCMessenger Swarm Orchestrator -- delegate work to the agent pool via ollama cloud models. Use SCMessenger_Clean as the project root for this workspace."
    },
    "swarm": {
      "template": "Launch an SCMessenger agent from the pool. Use SCMessenger_Clean as the project root for this workspace."
    }
  },
  "plugin": [],
  "disabled_providers": [
    "opencode",
    "opencode-go",
    "xiaomi",
    "XiaomiMiMo"
  ],
  "username": "scmessenger",
  "mode": {},
  "agent": {
    "build": {
      "description": "Default agent for Rust/mobile development with full tool permissions",
      "model": "openrouter/nex-agi/nex-n2-pro:free",
      "permissions": {
        "bash": true,
        "edit": true,
        "write": true,
        "read": true
      }
    },
    "plan": {
      "description": "Read-only analysis for code exploration and solution design",
      "model": "openrouter/openai/gpt-oss-20b:free",
      "permissions": {
        "bash": false,
        "edit": false,
        "write": false,
        "read": true
      }
    },
    "compose": {
      "description": "Orchestration mode for spec-driven development",
      "model": "openrouter/google/gemma-4-31b-it:free",
      "permissions": {
        "bash": true,
        "edit": true,
        "write": true,
        "read": true
      }
    },
    "rust-coder": {
      "description": "Rust core development, compilation fixes, and cargo operations",
      "model": "openrouter/google/gemma-4-31b-it:free",
      "fallback_model": "openrouter/openai/gpt-oss-20b:free",
      "permissions": {
        "bash": true,
        "edit": true,
        "write": true,
        "read": true
      }
    },
    "mobile-dev": {
      "description": "Android/Kotlin and iOS/Swift development",
      "model": "openrouter/nvidia/nemotron-nano-9b-v2:free",
      "permissions": {
        "bash": true,
        "edit": true,
        "write": true,
        "read": true
      }
    },
    "reviewer": {
      "description": "Reviews code for correctness, security, and philosophy compliance",
      "model": "openrouter/openai/gpt-oss-20b:free",
      "permissions": {
        "bash": false,
        "edit": false,
        "write": false,
        "read": true
      }
    },
    "fusion": {
      "description": "OpenRouter Fusion multi-model deliberation for complex reasoning. Paid: costs ~$0.02-0.10+ per request depending on prompt size.",
      "model": "openrouter/openrouter/fusion",
      "permissions": {
        "bash": true,
        "edit": true,
        "write": true,
        "read": true
      }
    },
    "free-router": {
      "description": "OpenRouter free-tier router: zero-cost, automatically picks the best available free model per request",
      "model": "openrouter/openrouter/free",
      "permissions": {
        "bash": true,
        "edit": true,
        "write": true,
        "read": true
      }
    }
  },
  "provider": {
    "openrouter": {
      "api": "https://openrouter.ai/api/v1",
      "name": "OpenRouter",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "headers": {
          "Authorization": "Bearer {env:OPENROUTER_API_KEY}"
        }
      },
      "models": {
        "nex-agi/nex-n2-pro:free": {
          "name": "Nex AGI: Nex-N2-Pro (free)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 262144,
            "output": 16384
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        },
        "openai/gpt-oss-20b:free": {
          "name": "OpenAI: gpt-oss-20b (free)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 131072,
            "output": 16384
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "google/gemma-4-31b-it:free": {
          "name": "Google: Gemma 4 31B (free)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 262144,
            "output": 16384
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          }
        },
        "nvidia/nemotron-nano-9b-v2:free": {
          "name": "NVIDIA: Nemotron Nano 9B V2 (free)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 128000,
            "output": 16384
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "liquid/lfm-2.5-1.2b-instruct:free": {
          "name": "LiquidAI: LFM2.5-1.2B-Instruct (free)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 32768,
            "output": 16384
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "openrouter/fusion": {
          "name": "OpenRouter: Fusion",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "cost": {
            "input": -1,
            "output": -1
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "openrouter/free": {
          "name": "OpenRouter: Free Router",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "mimo": {
      "api": "https://openrouter.ai/api/v1",
      "name": "MiMo Auto (OpenRouter fallback)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "headers": {
          "Authorization": "Bearer {env:OPENROUTER_API_KEY}"
        }
      },
      "models": {
        "mimo-auto": {
          "id": "openai/gpt-oss-20b:free",
          "name": "MiMo Auto",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "cost": {
            "input": 0,
            "output": 0
          },
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "xiaomi": {
      "api": "https://openrouter.ai/api/v1",
      "name": "OpenRouter",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "headers": {
          "Authorization": "Bearer {env:OPENROUTER_API_KEY}"
        }
      },
      "models": {}
    }
  }
}
